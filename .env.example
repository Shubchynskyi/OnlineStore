# ==============================================
# OnlineStore - Environment Variables
# ==============================================
# Copy this file to .env and adjust values as needed:
#   cp .env.example .env

# ==============================================
# PostgreSQL
# ==============================================
POSTGRES_USER=store
POSTGRES_PASSWORD=store_password
POSTGRES_DB=online_store

# Replication
# Keep this user separate from POSTGRES_USER for cleaner ops and safer password rotation.
POSTGRES_REPLICATION_USER=replicator
POSTGRES_REPLICATION_PASSWORD=replicator_password

# ==============================================
# Redis
# ==============================================
# Leave empty for no password (dev only)
REDIS_PASSWORD=

# ==============================================
# RabbitMQ
# ==============================================
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin_password

# ==============================================
# Keycloak
# ==============================================
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# ==============================================
# MinIO (S3-compatible storage)
# ==============================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ==============================================
# Grafana
# ==============================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ==============================================
# Vault (dev mode)
# ==============================================
VAULT_ROOT_TOKEN=dev-root-token

# ==============================================
# OpenTelemetry Collector (logs)
# ==============================================
# Optional. If not set or invalid, Loki will stay empty and the collector may log warnings.
# Docker Desktop (Windows): set to a WSL path like
# //wsl$/docker-desktop-data/data/docker/containers
DOCKER_LOGS_PATH=/var/lib/docker/containers

# ==============================================
# Application Host Ports
# ==============================================
# Override host-side ports if needed
OTEL_COLLECTOR_OTLP_GRPC_PORT=4317
OTEL_COLLECTOR_OTLP_HTTP_PORT=4318
OTEL_COLLECTOR_METRICS_PORT=8889
POSTGRES_PRIMARY_HOST_PORT=5432
POSTGRES_REPLICA_HOST_PORT=5433
REDIS_PORT=6379
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_PROMETHEUS_PORT=15692
ELASTICSEARCH_PORT=9200
KEYCLOAK_PORT=8180
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
JAEGER_UI_PORT=16686
JAEGER_COLLECTOR_PORT=14250
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
LOKI_PORT=3100
VAULT_PORT=8200

# ==============================================
# Telegram Bot
# ==============================================
TELEGRAM_BOT_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET_TOKEN=
TELEGRAM_MANAGER_NOTIFICATIONS_ENABLED=false
TELEGRAM_MANAGER_CHAT_ID=
TELEGRAM_MANAGER_CHAT_IDS=
TELEGRAM_MANAGER_USER_ID=
TELEGRAM_MANAGER_USER_IDS=
TELEGRAM_USER_RATE_LIMIT_MAX_EVENTS=20
TELEGRAM_USER_RATE_LIMIT_WINDOW=1m
TELEGRAM_MANAGER_RATE_LIMIT_MAX_ACTIONS=6
TELEGRAM_MANAGER_RATE_LIMIT_WINDOW=1m
TELEGRAM_DUPLICATE_CART_MUTATION_TTL=5s
TELEGRAM_DUPLICATE_MANAGER_ACTION_TTL=15s
BACKEND_SERVICE_AUTH_ENABLED=false
BACKEND_SERVICE_AUTH_CLIENT_ID=telegram-bot
BACKEND_SERVICE_AUTH_CLIENT_SECRET=
BACKEND_SERVICE_AUTH_SCOPE=

# ==============================================
# Telegram Bot AI Assistant
# ==============================================
TELEGRAM_INTERACTION_LOCK_TTL=4m
TELEGRAM_AI_ASSISTANT_ENABLED=false
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
TELEGRAM_AI_RATE_LIMIT_MAX_REQUESTS=4
TELEGRAM_AI_RATE_LIMIT_WINDOW=1m
OPENAI_MAX_COMPLETION_TOKENS=320
OPENAI_MAX_HISTORY_MESSAGES=10
OPENAI_MAX_RETRIEVED_PRODUCTS=3
OPENAI_MAX_PRODUCT_DESCRIPTION_CHARACTERS=160
OPENAI_MAX_USER_MESSAGE_CHARACTERS=500
OPENAI_MAX_SESSION_TOKENS=4000
OPENAI_TEMPERATURE=0.2
OPENAI_CONNECT_TIMEOUT=5s
OPENAI_READ_TIMEOUT=30s
OPENAI_RETRY_MAX_ATTEMPTS=2
OPENAI_RETRY_BACKOFF=500ms
